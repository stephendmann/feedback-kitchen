    "build": "npm run build:css"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@axe-core/puppeteer": "^4.11.3",
    "axe-core": "^4.11.4",
    "axe-html-reporter": "^2.2.11",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.60.0",
    "puppeteer": "^25.0.4",
    "tailwindcss": "^3.4.0"
  }
}
