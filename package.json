{
  "name": "feedback-kitchen",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "node node_modules/tailwindcss/lib/cli.js -i ./css/tailwind.src.css -o ./css/tailwind.out.css --minify",
