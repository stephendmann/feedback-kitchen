# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored (see .gitignore) — never commit real secrets.

# Required for the AI Assist panel to work locally.
ANTHROPIC_API_KEY=sk-ant-...

# Shared credentials the browser sends to /api/garnish.
# Use anything — these only gate the dev proxy, not Anthropic.
FK_PROXY_USER=devuser
FK_PROXY_PASSWORD=devpass

# Optional — leave at * for local dev.
FK_ALLOWED_ORIGINS=*

# Optional — override the port (default 3000).
# PORT=3001
